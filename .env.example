# ── Dominio y TLS (Caddy) ────────────────────────────────────────────────────
CADDY_DOMAIN=clinica.ejemplo.co
CADDY_EMAIL=admin@ejemplo.co

# ── Base de Datos (PostgreSQL 16) ─────────────────────────────────────────────
DB_NAME=sghcp
DB_USER=sghcp_app
DB_PASSWORD=changeme_strong_password_here
DB_HOST=postgres
DB_PORT=5432
# URL completa (usada por go-migrate y pgx)
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable

# ── Redis 7 ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password_here

# ── Cifrado (AEA — Envelope Encryption) ──────────────────────────────────────
# Generar con: openssl rand -hex 32
# NUNCA commitear esta variable. Rotar semestralmente.
MASTER_KEY=replace_with_64_char_hex_string_from_openssl_rand_hex_32

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_string
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# ── IA ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# tiny | base | small | medium — tradeoff velocidad/calidad; base recomendado para Bootstrap
WHISPER_MODEL=base
AI_SERVICE_URL=http://ai-service:8000

# ── Almacenamiento local ──────────────────────────────────────────────────────
# En producción (VPS): DATA_DIR=/data
# En desarrollo local: DATA_DIR=./data  (se crea con `make setup`)
DATA_DIR=./data
AUDIO_MAX_SIZE_MB=200

# ── Backup — Backblaze B2 ─────────────────────────────────────────────────────
B2_ACCOUNT_ID=changeme
B2_APPLICATION_KEY=changeme
B2_BUCKET_NAME=sghcp-backups
# Clave GPG para cifrar backups (fingerprint del key en el keyring del host)
GPG_RECIPIENT=admin@ejemplo.co

# ── Observabilidad ────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
# development | production
ENVIRONMENT=development
